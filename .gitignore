# ---------------------------------------------------------------------
# Build output
# ---------------------------------------------------------------------
build/
test_acme/fsroot/
*.prg
*.PRG
*.sym
*.lst
*.rlst

# The prebuilt library in dist/ (x16lib.bin, X16LIB.PRG, the generated
# */x16lib.inc bindings) is COMMITTED so it can be used without
# rebuilding; run .\dist.ps1 to regenerate it. X16LIB.PRG needs an
# exception from the global *.PRG rule above.
!dist/X16LIB.PRG

# ---------------------------------------------------------------------
# Bundled third-party tools -- not ours to redistribute.
#
# build.ps1 expects both of these to exist. See README.md:
#   acme/      ACME 0.97   https://sourceforge.net/projects/acme-crossass/
#   emulator/  x16emu r49  https://github.com/X16Community/x16-emulator
#              (needs rom.bin from https://github.com/X16Community/x16-rom)
# ---------------------------------------------------------------------
# (anchored to the root: dist/acme etc. hold committed bindings)
/acme/
/emulator/

# ---------------------------------------------------------------------
# Official X16 reference documents -- freely available upstream, kept
# locally for offline use. The ForthX16 help pages in doc/*.TXT stay.
# ---------------------------------------------------------------------
doc/Commander X16 Programmer's Reference Guide.pdf
doc/X16 Reference - 09 - VERA Programmer's Reference.md
doc/X16 Reference - 10 - VERA FX Reference.md
doc/*.pdf

# ---------------------------------------------------------------------
# Editor / OS noise
# ---------------------------------------------------------------------
Thumbs.db
desktop.ini
.DS_Store
*.swp
*~

# ca65 build products
*.o


# Bundled third-party assemblers -- not ours to redistribute (see README)
# (anchored to the root: dist/64tass etc. hold committed bindings)
/cc65/
/64tass/
/kickass/

tools/__pycache__/
